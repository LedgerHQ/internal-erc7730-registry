{
  "$schema": "../../specs/erc7730-v2.schema.json",
  "context": {
    "$id": "0GValidator",
    "contract": {
      "deployments": [
        { "chainId": 16661, "address": "0xa6f8418a5c6a0e6a8d554dc42497b14335746eb1" },
        { "chainId": 16661, "address": "0x712a30816a8756c8fdb78de63db55aa70d3cf3b4" },
        { "chainId": 16661, "address": "0x859050edf0151c8fc317eaacf84601e344231347" }
      ],
      "factory": {
        "deployments": [
          { "chainId": 16661, "address": "0xea224dBB52F57752044c0C86aD50930091F561B9" }
        ],
        "deployEvent": "ValidatorCreated(bytes indexed pubkey, address indexed validator)"
      }
    }
  },
  "metadata": {
    "owner": "0G",
    "contractName": "0GValidator",
    "info": { "url": "https://0g.ai" },
    "constants": {
      "nativeTokenTicker": "0G",
      "nativeDecimals": 18
    }
  },
  "display": {
    "formats": {
      "delegate(address delegatorAddress)": {
        "intent": "Delegate to validator",
        "fields": [
          {
            "path": "@.to",
            "label": "Validator contract",
            "format": "addressName",
            "params": { "types": ["contract"] },
            "visible": "always"
          },
          {
            "path": "#.delegatorAddress",
            "label": "Delegator",
            "format": "addressName",
            "params": { "types": ["eoa"] },
            "visible": "always"
          },
          {
            "path": "@.value",
            "label": "Delegate amount",
            "format": "amount",
            "visible": "always"
          }
        ]
      },
      "undelegate(address withdrawalAddress, uint256 shares)": {
        "intent": "Undelegate from validator",
        "fields": [
          {
            "path": "@.to",
            "label": "Validator contract",
            "format": "addressName",
            "params": { "types": ["contract"] },
            "visible": "always"
          },
          {
            "path": "#.withdrawalAddress",
            "label": "Withdraw to",
            "format": "addressName",
            "params": { "types": ["eoa"] },
            "visible": "always"
          },
          {
            "path": "#.shares",
            "label": "Shares to undelegate",
            "format": "unit",
            "params": { "base": "shares", "decimals": 18 },
            "visible": "always"
          },
          {
            "path": "@.value",
            "label": "Withdrawal fee",
            "format": "amount",
            "visible": "always"
          }
        ]
      },
      "withdrawCommission(address withdrawalAddress)": {
        "intent": "Withdraw validator commission",
        "fields": [
          {
            "path": "@.to",
            "label": "Validator contract",
            "format": "addressName",
            "params": { "types": ["contract"] },
            "visible": "always"
          },
          {
            "path": "#.withdrawalAddress",
            "label": "Withdraw to",
            "format": "addressName",
            "params": { "types": ["eoa"] },
            "visible": "always"
          }
        ]
      }
    }
  }
}
